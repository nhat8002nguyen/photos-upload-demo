# Copy to .env in this directory: cp env.example .env
# docker compose loads .env for variable substitution and passes values into containers.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=photoupload

# Must match POSTGRES_* above (same user, password, db name, host `postgres`).
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/photoupload?schema=public

AUTH_SECRET=change-me-at-least-16-chars-random

# Optional: force Secure session cookies (see src/lib/auth.ts). Usually leave unset;
# cookies use Secure only when X-Forwarded-Proto is https.
# COOKIE_SECURE=true

# Optional — for scripts/setup-ssl.sh and HTTPS (DNS must point to this server first)
# DOMAIN_NAME=photos.example.com
# EMAIL_FOR_SSL=you@example.com
