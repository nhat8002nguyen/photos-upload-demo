DATABASE_URL="postgresql://postgres:postgres@localhost:5432/photoupload"
AUTH_SECRET="replace-with-long-random-string-for-production"
UPLOAD_DIR="./uploads"

# Optional: force session cookie Secure flag (overrides X-Forwarded-Proto). Use COOKIE_SECURE=true
# behind HTTPS-only proxies if proto header is wrong. Leave unset for normal behavior.
# COOKIE_SECURE=true
